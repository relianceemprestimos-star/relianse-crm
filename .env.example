APP_NAME=Relianse CRM
NODE_ENV=production

# Public URLs
CRM_DOMAIN=SEU_DOMINIO_AQUI
CRM_WWW_DOMAIN=www.SEU_DOMINIO_AQUI
APP_URL=https://SEU_DOMINIO_AQUI
FRONTEND_URL=https://SEU_DOMINIO_AQUI
BACKEND_URL=https://SEU_DOMINIO_AQUI/api
CORS_ORIGIN=https://SEU_DOMINIO_AQUI

# Ports
BACKEND_PORT=4000
FRONTEND_PORT=3000
PORT=4000

# Database and storage
SQLITE_PATH=/app/data/relianse-crm.sqlite
DATABASE_PATH=/app/data/relianse-crm.sqlite
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs
MAX_UPLOAD_SIZE_MB=25

# Auth
JWT_SECRET=TROQUE_POR_UMA_CHAVE_FORTE
CREDENTIALS_ENCRYPTION_KEY=TROQUE_POR_UMA_CHAVE_FORTE_PARA_CREDENCIAIS
TOKEN_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

# Frontend API base.
# Leave empty when frontend and backend share the same domain through Caddy.
VITE_API_URL=
VITE_BACKEND_PROXY_TARGET=http://localhost:4000

# Python/Playwright
PYTHON_BIN=/opt/venv/bin/python

# Consulta Ribeirao / SAEC Consiglog
RIBEIRAO_PROJECT_ROOT=/app/backend/src/services/averbadores/ribeirao/vendor/worker
RIBEIRAO_AVERBADOR_URL=URL_DO_PORTAL_RIBEIRAO
RIBEIRAO_AVERBADOR_CONSULTA_URL=
RIBEIRAO_AVERBADOR_LOGIN=
RIBEIRAO_AVERBADOR_PASSWORD=
RIBEIRAO_AVERBADOR_ORGAO=ORGAO_CONVENIO_RIBEIRAO
RIBEIRAO_HEADLESS=true

# Consulta cadastral / Datafour (Nova Vida legado/fallback)
PHONE_LOOKUP_ENABLED=true
PHONE_LOOKUP_MAX_PER_RUN=50
PHONE_LOOKUP_DELAY_SECONDS=5
PHONE_LOOKUP_SOURCE=datafour
DATAFOUR_URL=https://datafile.com.br/login/
DATAFOUR_API_URL=https://api.datafile.com.br/
DATAFOUR_USERNAME=
DATAFOUR_LOGIN=
DATAFOUR_EMAIL=
DATAFOUR_PASSWORD=
DATAFOUR_USE_360=false
NOVA_VIDA_URL=URL_DO_PORTAL_NOVA_VIDA
NOVA_VIDA_USERNAME=
NOVA_VIDA_USER=
NOVA_VIDA_CLIENT=
NOVA_VIDA_PASSWORD=
NOVA_VIDA_HEADLESS=true
NOVA_VIDA_STORAGE_STATE=/app/data/nova_vida_storage_state.json

# Optional controlled fixture for tests without querying the real portal.
NOVA_VIDA_FIXTURE_PATH=

# WhatsApp API
WHATSAPP_PROVIDER=unofficial
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE_ID=
WHATSAPP_TOKEN_ENCRYPTION_KEY=TROQUE_POR_UMA_CHAVE_FORTE_PARA_WHATSAPP
WHATSAPP_DEFAULT_COUNTRY_CODE=55
WHATSAPP_DEFAULT_NUMBER=
WHATSAPP_SEND_DELAY_SECONDS=120
WHATSAPP_DAILY_LIMIT_PER_NUMBER=30
WHATSAPP_ENABLED=true
WHATSAPP_MANUAL_ONLY=true

# Motor interno de CAPTCHA
CAPTCHA_ENGINE_ENABLED=true
CAPTCHA_DEFAULT_MODE=hybrid
CAPTCHA_INTERNAL_OCR_ENABLED=true
CAPTCHA_INTERNAL_OCR_MIN_CONFIDENCE=0.75
CAPTCHA_EXTERNAL_PROVIDER=capsolver
CAPTCHA_EXTERNAL_PROVIDER_ENABLED=false

# Provider externo opcional: CapSolver
CAPSOLVER_ENABLED=false
CAPSOLVER_API_KEY=
CAPSOLVER_DAILY_LIMIT=100
CAPSOLVER_BATCH_LIMIT=20
CAPSOLVER_TIMEOUT_MS=120000
CAPSOLVER_POLL_INTERVAL_MS=3000

# Meta WhatsApp Business Platform - opcional/futuro
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_WABA_ID=
META_WHATSAPP_VERIFY_TOKEN=
