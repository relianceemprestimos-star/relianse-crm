APP_NAME=Relianse CRM
NODE_ENV=production

# Public URLs
CRM_DOMAIN=reliancecrm.com.br
CRM_WWW_DOMAIN=www.reliancecrm.com.br
APP_URL=https://reliancecrm.com.br
FRONTEND_URL=https://reliancecrm.com.br
BACKEND_URL=https://reliancecrm.com.br/api
CORS_ORIGIN=https://reliancecrm.com.br

# App ports
BACKEND_PORT=4000
FRONTEND_PORT=3000
PORT=4000

# Database and storage
SQLITE_PATH=/app/data/relianse-crm.sqlite
DATABASE_PATH=/app/data/relianse-crm.sqlite
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs
MAX_UPLOAD_SIZE_MB=25

# Auth
JWT_SECRET=troque_essa_chave_em_producao
TOKEN_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

# Frontend API base. Leave empty when frontend and backend share the same domain.
VITE_API_URL=
VITE_BACKEND_PROXY_TARGET=http://localhost:4000

# Ribeirao module
PYTHON_BIN=/opt/venv/bin/python
RIBEIRAO_PROJECT_ROOT=/app/backend/src/services/averbadores/ribeirao/vendor/worker
RIBEIRAO_AVERBADOR_URL=COLOQUE_A_URL_REAL_DO_AVERBADOR_AQUI
RIBEIRAO_AVERBADOR_CONSULTA_URL=
RIBEIRAO_AVERBADOR_LOGIN=
RIBEIRAO_AVERBADOR_PASSWORD=
RIBEIRAO_AVERBADOR_ORGAO=Prefeitura de Ribeirao Preto
RIBEIRAO_HEADLESS=true

# Busca de Telefones / Nova Vida
PHONE_LOOKUP_ENABLED=true
PHONE_LOOKUP_MAX_PER_RUN=50
PHONE_LOOKUP_DELAY_SECONDS=5
PHONE_LOOKUP_SOURCE=nova_vida
NOVA_VIDA_URL=https://congonhas.novavidati.com.br
NOVA_VIDA_USERNAME=
NOVA_VIDA_USER=
NOVA_VIDA_PASSWORD=
NOVA_VIDA_HEADLESS=false
# Opcional para testes controlados sem consultar o portal real.
NOVA_VIDA_FIXTURE_PATH=
