APP_NAME=Relianse CRM
NODE_ENV=development
PORT=3001

SQLITE_PATH=./data/relianse-crm.sqlite
DATABASE_PATH=./data/relianse-crm.sqlite
UPLOAD_DIR=./uploads
LOG_DIR=./logs
MAX_UPLOAD_SIZE_MB=25

JWT_SECRET=troque_essa_chave_em_producao
CREDENTIALS_ENCRYPTION_KEY=troque_essa_chave_para_credenciais
TOKEN_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

CORS_ORIGIN=http://localhost:5173,http://localhost:3000

PYTHON_BIN=python
RIBEIRAO_PROJECT_ROOT=
RIBEIRAO_AVERBADOR_URL=URL_DO_PORTAL_RIBEIRAO
RIBEIRAO_AVERBADOR_CONSULTA_URL=
RIBEIRAO_AVERBADOR_LOGIN=
RIBEIRAO_AVERBADOR_PASSWORD=
RIBEIRAO_AVERBADOR_ORGAO=ORGAO_CONVENIO_RIBEIRAO
RIBEIRAO_HEADLESS=true

PHONE_LOOKUP_ENABLED=true
PHONE_LOOKUP_MAX_PER_RUN=50
PHONE_LOOKUP_DELAY_SECONDS=5
PHONE_LOOKUP_SOURCE=nova_vida
NOVA_VIDA_URL=URL_DO_PORTAL_NOVA_VIDA
NOVA_VIDA_USERNAME=
NOVA_VIDA_USER=
NOVA_VIDA_CLIENT=
NOVA_VIDA_PASSWORD=
NOVA_VIDA_HEADLESS=true
NOVA_VIDA_STORAGE_STATE=./data/nova_vida_storage_state.json
NOVA_VIDA_FIXTURE_PATH=
